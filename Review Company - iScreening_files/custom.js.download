
function showAlertPopup(message, title, callback) {
    title = title == null ? "Alert" : title;
    $('#alert-message-content').html(message);
    $('#alert-message').dxPopup({
        showTitle: true,
        showCloseButton: true,
        title: title,
        visible: true,
        width: 500,
        height: 'auto',
        onHidden: function (p, w, m) {

            var wp = $('#alert-message').parent();
            $('#alert-message').remove();
            wp.append('<div id="alert-message"><p id="alert-message-content"></p></div>');
            if (callback != null)
                callback.apply();

        }
    });
}

function showConfirm(message, title) {
    var result = DevExpress.ui.dialog.confirm(message, title);
    return result;
}

(function ($) {
    $(".dynamic-select-button").click(function () {
        $elem = $(this);
        var $dropdown = $elem.closest(".dynamic-select").find(".dynamic-select-dropdown");
        var $list = $elem.closest(".dynamic-select").next(".dynamic-select-list");
        var text = $dropdown.find("option:selected").text();

        if (text == "")
            return;

        if (text == "Select All") {
            //put the whole list in the list below.
            $dropdown.find("option").each(function () {

                if ($(this).val() != "0" && $list.find("li input[value='" + $(this).text() + "']").length <= 0) {

                    $list.append(
                        $("<li/>").addClass("nav nav-tabs nav-stacked")
                            .append("<input type='hidden' name='" + $dropdown.attr('buildupname') + "[" + $("li.nav").length + "].Id' value='" + $(this).val() + "'/>")
                            .append("<input type='hidden' name='" + $dropdown.attr('buildupname') + "[" + $("li.nav").length + "].Name' value='" + $(this).text() + "'/>")
                            .append("<label>" + $(this).text() + "<label/>")
                            .append($("<button class='fa fa-minus minusBtn fltRgt dynamic-select-list-button' type='button'>-</button>").click(function () {
                                $(this).closest("li.nav").remove();
                                reindex();
                            })
                            )
                    );

                    $dropdown.val("");
                }

            });

            return;
        }

        if ($dropdown.val() != "0" && $list.find("li input[value='" + $dropdown.find("option:selected").text() + "']").length <= 0) {

            $list.append(
                $("<li/>").addClass("nav nav-tabs nav-stacked")
