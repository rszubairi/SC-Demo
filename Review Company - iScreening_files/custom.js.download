function selectAllEventWithName($, selectAllId, selectionClass) {




    $("#" + selectAllId).click(function (e, elem) {
        $this = this;
        $("." + selectionClass).each(function () { this.checked = $this.checked; });
    });

    $("." + selectionClass).click(function () {
        $this = this;
        if ($this.checked) {
            $("." + selectionClass).each(function () {
                if (!this.checked) {

                    if (typeof (vm) != 'undefined') {
                        if (vm.selectAllClicked)
                            vm.selectAllClicked(false);
                    }

                    $("#" + selectAllId)[0].checked = false;
                    return false;
                } else {
                    if (typeof (vm) != 'undefined') {
                        if (vm.selectAllClicked)
                            vm.selectAllClicked(true);
                    }

                    $("#" + selectAllId)[0].checked = true;
                }
            });
            if (typeof (vm) != 'undefined' && vm.selectedIds) {
                vm.selectedIds.push(parseInt($(this).val()));
            }
        } else {
            $("#" + selectAllId)[0].checked = false;
            //exclude from vm.selectedIds
            if (typeof (vm) != 'undefined' && vm.selectedIds) {
                vm.selectedIds.remove(parseInt($(this).val()));
                vm.selectAllClicked(false);
            }
        }
    });
}

function cleanVariables(str) {
    return str.replace(/\{([^)]+)\}/g, stripHTML);
}

function stripHTML(html) {
    var sandbox = document.implementation.createHTMLDocument().body;
    sandbox.innerHTML = html;
    return sandbox.textContent;
}

function isDate(txtDate) {
    var currVal = txtDate;
    if (currVal == '')
        return false;

    //Declare Regex  
    var rxDatePattern = /^(\d{1,2})(\/|-)(\d{1,2})(\/|-)(\d{4})$/;
    var dtArray = currVal.match(rxDatePattern); // is format OK?

    if (dtArray == null)
        return false;

    //Checks for dd/mm/yyyy format.
    dtDay = dtArray[1];
    dtMonth = dtArray[3];
    dtYear = dtArray[5];

    if (dtMonth < 1 || dtMonth > 12)
        return false;
    else if (dtDay < 1 || dtDay > 31)
        return false;
    else if ((dtMonth == 4 || dtMonth == 6 || dtMonth == 9 || dtMonth == 11) && dtDay == 31)
        return false;
    else if (dtMonth == 2) {
        var isleap = (dtYear % 4 == 0 && (dtYear % 100 != 0 || dtYear % 400 == 0));
        if (dtDay > 29 || (dtDay == 29 && !isleap))
            return false;
    }
    return true;
}

function addMessage(message, containerId) {
    $class = "alert " + ((message.trim().indexOf("Error") == 0) ? "alert-danger" : "alert-success") + " alert-dismissible";
    $("#" + containerId).append(
        $("<div/>").addClass($class).attr("role", "alert").append(
            $("<button/>").addClass("close").attr("type", "button").attr("data-dismiss", "alert").append(
                $("<span/>").attr("aria-hidden", "true").html("&times;")
            ).append(
                $("<span/>").addClass("sr-only").html("Close")
            )
        ).append(message)
    );
}
