
jQuery.fn.ForceNumericOnly = function (allowNegative) {
    if (allowNegative == null) {
        allowNegative = false;
    }

    return this.each(function () {
        $this = $(this);

        $this.keydown(function (e) {
            var val = $(this).val();

            if (val == 0)
                val = "";

            var key = e.charCode || e.keyCode || 0;

            if ((allowNegative == true && val.length == 0 && key == 109) ||
                (allowNegative == true && val.length == 0 && key == 189 && (e.shiftKey == false || e.shiftKey == 'false'))) {
                return true;
            }
            // allow backspace, tab, delete, enter, arrows, numbers and keypad numbers ONLY
            // home, end, period, and numpad decimal
            return (
                key == 8 ||
                key == 9 ||
                key == 13 ||
                key == 46 ||
                (val.indexOf('.') < 0 && key == 110) ||
                (val.indexOf('.') < 0 && key == 190 && (e.shiftKey == false || e.shiftKey == 'false')) ||
                (key >= 35 && key <= 40) ||
                (key >= 48 && key <= 57) ||
                (key >= 96 && key <= 105));
        });


    });
};

jQuery.fn.RoundToDecimal = function (places) {
    var value = this.val() == "" ? 0 : this.val();

    if (!isNaN(value)) {
        var num = Math.pow(10, places);
        var value = Math.round(parseFloat(value) * num) / num;
        this.val(value.toFixed(2));
    }
};


